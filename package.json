{
  "name": "purrmadeath",
  "version": "1.4.0",
  "description": "2D co-op roguelike - base building, procedural world, up to 4 players",
  "author": "w1ck3ds0d4",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "server:dev": "nodemon --watch server --watch shared --ext ts --exec \"tsx server/server.ts\"",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "server": "tsx server/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src server shared --ext .ts",
    "typecheck": "tsc --noEmit",
    "check-version": "node scripts/check-version.cjs",
    "build:server": "npx esbuild server/server.ts --bundle --platform=node --format=cjs --outfile=resources/server/server.cjs --alias:@shared=./shared",
    "build:win": "node scripts/check-version.cjs && npm run build:server && electron-vite build && node -e \"require('fs').mkdirSync('out/server',{recursive:true});require('fs').copyFileSync('resources/server/server.cjs','out/server/server.cjs')\" && electron-builder --win",
    "publish": "node scripts/check-version.cjs && npm run build:server && electron-vite build && node -e \"require('fs').mkdirSync('out/server',{recursive:true});require('fs').copyFileSync('resources/server/server.cjs','out/server/server.cjs')\" && electron-builder --win --publish always",
    "aws:start": "node scripts/aws.mjs start",
    "aws:stop": "node scripts/aws.mjs stop",
    "aws:status": "node scripts/aws.mjs status"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "pixi.js": "^8.18.1",
    "simplex-noise": "^4.0.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.3",
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "nodemon": "^3.1.4",
    "tsx": "^4.22.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.6"
  },
  "build": {
    "appId": "com.purrmadeath.app",
    "productName": "Purrmadeath",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/server/",
        "to": "server/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "releaseInfo": {
      "releaseName": "Purrmadeath v${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "w1ck3ds0d4",
      "repo": "Purrmadeath"
    }
  }
}
